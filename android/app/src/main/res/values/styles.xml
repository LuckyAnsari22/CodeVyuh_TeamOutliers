<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══ BASE STYLES (Required for dot-notation inheritance) ═══ -->
    <style name="GreenIQ" />
    <style name="GreenIQ.Text" />
    <style name="GreenIQ.Chip" />

    <!-- ═══ GLASSMORPHISM CARD ═══ -->
    <style name="GreenIQ.GlassCard">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">24dp</item>
    </style>

    <style name="GreenIQ.GlassCard.Elevated">
        <item name="cardBackgroundColor">@color/bg_card_elevated</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- ═══ BUTTONS ═══ -->
    <style name="GreenIQ.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingLeft">32dp</item>
        <item name="android:paddingRight">32dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="GreenIQ.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingLeft">32dp</item>
        <item name="android:paddingRight">32dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ═══ TEXT STYLES ═══ -->
    <style name="GreenIQ.Text.Hero">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.05</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="GreenIQ.Text.SectionTitle">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <style name="GreenIQ.Text.Body">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <style name="GreenIQ.Text.Label">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_accent</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="GreenIQ.Text.StatNumber">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="GreenIQ.Text.StatLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- ═══ SECTION TAG CHIP ═══ -->
    <style name="GreenIQ.Chip.Tag">
        <item name="android:background">@drawable/bg_tag_chip</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ═══ INPUT FIELDS ═══ -->
    <style name="GreenIQ.Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/border_subtle</item>
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- ═══ DIALOG ═══ -->
    <style name="GreenIQ_Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_card</item>
    </style>


    <!-- ═══ BOTTOM NAVIGATION ═══ -->
    <style name="GreenIQ.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_darker</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- ═══ DIMENS ═══ -->
    <dimen name="card_radius">20dp</dimen>
    <dimen name="card_padding">24dp</dimen>
    <dimen name="section_padding_h">24dp</dimen>
    <dimen name="section_padding_v">32dp</dimen>
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_sm">8dp</dimen>
    <dimen name="spacing_md">16dp</dimen>
    <dimen name="spacing_lg">24dp</dimen>
    <dimen name="spacing_xl">32dp</dimen>
    <dimen name="spacing_2xl">48dp</dimen>
</resources>
