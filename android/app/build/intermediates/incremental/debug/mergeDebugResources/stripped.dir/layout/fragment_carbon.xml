<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            style="@style/GreenIQ.Chip.Tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GLEC v3 · WTW · Live"
            android:layout_marginBottom="12dp" />

        <TextView
            style="@style/GreenIQ.Text.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Live Carbon Calculator"
            android:layout_marginBottom="4dp" />

        <TextView
            style="@style/GreenIQ.Text.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/carbon_subtitle"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="24dp" />

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/GreenIQ.GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1: Origin & Destination -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            style="@style/GreenIQ.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/carbon_origin"
                            android:layout_marginBottom="6dp" />
                        <Spinner
                            android:id="@+id/spinnerOrigin"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:popupBackground="@color/bg_card" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            style="@style/GreenIQ.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/carbon_dest"
                            android:layout_marginBottom="6dp" />
                        <Spinner
                            android:id="@+id/spinnerDest"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:popupBackground="@color/bg_card" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Weight & Vehicle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            style="@style/GreenIQ.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/carbon_weight"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/editWeight"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:text="18000"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:importantForAutofill="no" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            style="@style/GreenIQ.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/carbon_vehicle"
                            android:layout_marginBottom="6dp" />
                        <Spinner
                            android:id="@+id/spinnerVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:popupBackground="@color/bg_card" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Calculate Button -->
                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/cta_calculate"
                    android:textColor="@color/bg_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:letterSpacing="0.05"
                    android:background="@drawable/bg_button_gradient" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressLoading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/accent_cyan"
            android:visibility="gone" />

        <!-- Results Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            style="@style/GreenIQ.GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Main Emission Number -->
                <TextView
                    android:id="@+id/tvEmissions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/health_pulse"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carbon_result_label"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp" />

                <!-- Grade Badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/bg_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_tag_chip" />

                    <TextView
                        android:id="@+id/tvPerTonKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/accent_cyan"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <!-- Data Provenance / How calculated -->
                <LinearLayout
                    android:id="@+id/provenanceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:background="#0AFFFFFF"
                    android:padding="12dp">
                    
                    <LinearLayout
                        android:id="@+id/btnToggleProvenance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📊 How this was calculated"
                            android:textColor="@color/accent_cyan"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/provenanceIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textColor="@color/accent_cyan"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/provenanceContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">
                        
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Emission factor: 0.0788 kg CO₂e/ton-km [GLEC Framework v3]"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Road correction: 1.05× [ARAI BS-VI Emission Study, 2022]"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Load factor adjustment: weight/25t capacity"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Methodology: EN 16258:2012 Well-to-Wheel (WTT + TTW)"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                            
                    </LinearLayout>
                </LinearLayout>

                <!-- Comparison Bar -->
                <ProgressBar
                    android:id="@+id/comparisonBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_button_gradient" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="You"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/carbon_benchmark"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Recommendation -->
                <TextView
                    android:id="@+id/tvRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="14dp"
                    android:background="#0D00FF88"
                    android:textColor="@color/health_green"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <View android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
