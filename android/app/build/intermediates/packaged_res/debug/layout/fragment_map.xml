<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Full-screen OpenGL 3D Road Map -->
    <android.opengl.GLSurfaceView
        android:id="@+id/glMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Info Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_gravity="top"
        android:background="#CC050508">

        <View
            android:id="@+id/liveDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/health_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE · 3D FREIGHT NETWORK"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginStart="8dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60 FPS"
            android:textColor="@color/health_green"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:alpha="0.6" />

    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="16dp"
        android:background="#E6050508">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/map_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnNeutral"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Neutral"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_field"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDisease"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Disease"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/sick_red"
                android:background="@drawable/bg_input_field"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btnHeal"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="GREENIQ"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/health_green"
                android:background="@drawable/bg_input_field"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
